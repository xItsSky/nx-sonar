{
  "name": "nx-sonar-e2e",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "nx-sonar-e2e/src",
  "implicitDependencies": ["nx-sonar"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "nx-sonar-e2e/jest.config.cts",
        "runInBand": true
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p nx-sonar-e2e/tsconfig.spec.json"
      }
    }
  }
}
